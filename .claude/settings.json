{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/bash-syntax-check.sh",
            "timeout": 10,
            "statusMessage": "Checking bash syntax..."
          }
        ]
      }
    ]
  }
}
